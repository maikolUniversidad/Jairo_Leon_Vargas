# ─────────────────────────────────────────────────────────────
# UTL 360 – Variables de entorno
# Copia este archivo a `.env.local` y completa los valores.
# NUNCA subas `.env.local` ni la SERVICE_ROLE_KEY a git ni al cliente.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SOLO SERVIDOR. Bypassa RLS. Jamás usar en componentes cliente ni con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública del sitio (para redirects de auth, emails, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# IA (server only). Proveedor: "deepseek" (por defecto) u "openai".
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
# Opcional: sobrescribir modelos
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_MODEL=gpt-4o-mini

# Email transaccional (server only) — canal de notificaciones por correo
RESEND_API_KEY=
RESEND_FROM="UTL 360 <onboarding@resend.dev>"

# Notificaciones push (FCM) y WhatsApp (server only) — opcionales
FCM_SERVER_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Analítica
NEXT_PUBLIC_GA_ID=
