# ─────────────────────────────────────────────────────────────
# UTL 360 – Variables de entorno
# Copia este archivo a `.env.local` y completa los valores.
# NUNCA subas `.env.local` ni la SERVICE_ROLE_KEY a git ni al cliente.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SOLO SERVIDOR. Bypassa RLS. Jamás usar en componentes cliente ni con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública del sitio (para redirects de auth, emails, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Conexión Postgres directa (solo local) para correr migraciones con scripts/db-exec.mjs.
# Cópiala desde Supabase → Connect → Session pooler. NUNCA subir con la contraseña real.
DATABASE_URL=

# IA (server only). Proveedor: "deepseek" (por defecto) u "openai".
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
# Opcional: sobrescribir modelos
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_MODEL=gpt-4o-mini
# Asistente IA (chat): la visión de imágenes usa un modelo OpenAI (gpt-4o-mini) y
# la transcripción de voz usa Whisper (requiere OPENAI_API_KEY).
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# Base de conocimiento (RAG): embeddings con OpenAI (requiere OPENAI_API_KEY).
# El modelo debe producir 1536 dims para coincidir con la columna vector(1536).
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Email transaccional (server only) — canal de notificaciones por correo
RESEND_API_KEY=
RESEND_FROM="UTL 360 <onboarding@resend.dev>"

# Notificaciones push (FCM) y WhatsApp (server only) — opcionales
FCM_SERVER_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Cron (server only) — protege /api/cron/*. Vercel lo envía como
# "Authorization: Bearer <CRON_SECRET>" en los crons. Genera uno aleatorio.
CRON_SECRET=

# Monitoreo de personas (Comunicaciones) — fuentes OPCIONALES (server only).
# Noticias vía Google News RSS funcionan sin clave. Estas amplían la cobertura:
X_BEARER_TOKEN=          # X/Twitter API v2 (búsqueda reciente de posts)
NEWSAPI_KEY=             # newsapi.org (noticias adicionales)

# Producción de video · IA (Comunicaciones) — todas OPCIONALES (server only).
# Sin llave, cada capacidad cae a modo mock/borrador.
# Higgsfield Cloud API (imagen/video): https://cloud.higgsfield.ai
HIGGSFIELD_API_KEY=
# HIGGSFIELD_BASE_URL=https://api.higgsfield.ai
# HIGGSFIELD_IMAGE_MODEL=flux
# HIGGSFIELD_VIDEO_MODEL=higgsfield
# Predictor de viralidad nativo (job "brain_activity"): Hook Score, Hold Rate, Viral Score.
# Solo si tu plan expone un endpoint/nombre distinto:
# HIGGSFIELD_VIRALITY_URL=https://api.higgsfield.ai/v1/generations
# HIGGSFIELD_VIRALITY_TASK=brain_activity
# Búsqueda web para investigación de temas. Proveedor: "tavily" (por defecto) o "serper".
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=

# Avatares (Comunicaciones) — voz. Lo RECOMENDADO es conectarla en el dashboard:
# Configuración → Integraciones (se guarda en app_secrets). Esto es solo respaldo.
# La imagen/video reutiliza HIGGSFIELD_API_KEY / HIGGSFIELD_BASE_URL de arriba.
ELEVENLABS_API_KEY=      # elevenlabs.io → Profile → API Key

# Analítica
NEXT_PUBLIC_GA_ID=

# Google Drive (OAuth · cuenta única). Crea credenciales "Aplicación web" en Google Cloud.
# Redirect URIs: <SITE_URL>/api/google/callback  (local y producción)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
